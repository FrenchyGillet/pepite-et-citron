# ── Supabase (obligatoire en production) ─────────────────────────────────────
VITE_SUPABASE_URL=https://VOTRE_PROJET.supabase.co
VITE_SUPABASE_ANON_KEY=VOTRE_CLE_ANON

# ── Stripe (obligatoire pour le plan Pro) ─────────────────────────────────────
# Clé secrète — NE PAS exposer côté client (pas de préfixe VITE_)
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# IDs des prix Stripe (Dashboard → Produits → Pépite & Citron Pro)
STRIPE_PRICE_MONTHLY=price_...   # 2,99 €/mois
STRIPE_PRICE_ANNUAL=price_...    # 12,99 €/an

# Service role Supabase — NE PAS exposer côté client
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# URL de l'app (utilisée pour les redirections Stripe)
VITE_APP_URL=https://pepite-et-citron.vercel.app

# ── Monitoring (optionnel) ────────────────────────────────────────────────────
VITE_SENTRY_DSN=
VITE_APP_VERSION=
